{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "docs/inventory.schema.json",
  "title": "Documentation Inventory Index",
  "type": "object",
  "required": [
    "generated_at",
    "root",
    "scope_paths",
    "excluded_paths",
    "totals",
    "subsystem_counts",
    "feature_entries",
    "file_entries"
  ],
  "additionalProperties": false,
  "properties": {
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "root": {
      "type": "string"
    },
    "scope_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "excluded_paths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "totals": {
      "type": "object",
      "required": [
        "files_scoped",
        "features_total",
        "subsystems_total"
      ],
      "additionalProperties": false,
      "properties": {
        "files_scoped": {
          "type": "integer",
          "minimum": 0
        },
        "features_total": {
          "type": "integer",
          "minimum": 0
        },
        "subsystems_total": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "subsystem_counts": {
      "type": "object",
      "additionalProperties": {
        "type": "integer",
        "minimum": 0
      }
    },
    "feature_entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "feature_id",
          "feature_name",
          "user_value",
          "entrypoints",
          "owner_files",
          "runtime_dependencies",
          "ipc_channels",
          "storage_keys/files",
          "commands",
          "tests_covering",
          "status",
          "risk_notes",
          "primary_subsystem"
        ],
        "additionalProperties": false,
        "properties": {
          "feature_id": {
            "type": "string"
          },
          "feature_name": {
            "type": "string"
          },
          "user_value": {
            "type": "string"
          },
          "entrypoints": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "window",
                "page",
                "control",
                "main",
                "service",
                "script"
              ]
            }
          },
          "owner_files": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "runtime_dependencies": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "ipc_channels": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "storage_keys/files": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "commands": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "tests_covering": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "experimental",
              "internal",
              "staging"
            ]
          },
          "risk_notes": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "primary_subsystem": {
            "type": "string",
            "enum": [
              "App shell/UI",
              "Main process/IPC/services",
              "Brain modules/wrappers/math",
              "Data catalogs/contracts",
              "Pipeline/gates/release scripts",
              "Governance/agents/skills",
              "Test suite"
            ]
          }
        }
      }
    },
    "file_entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "path",
          "primary_subsystem",
          "feature_ids",
          "status"
        ],
        "additionalProperties": false,
        "properties": {
          "path": {
            "type": "string"
          },
          "primary_subsystem": {
            "type": "string",
            "enum": [
              "App shell/UI",
              "Main process/IPC/services",
              "Brain modules/wrappers/math",
              "Data catalogs/contracts",
              "Pipeline/gates/release scripts",
              "Governance/agents/skills",
              "Test suite"
            ]
          },
          "feature_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "active",
              "experimental",
              "internal",
              "staging"
            ]
          }
        }
      }
    }
  }
}
