{
  "schema_version": 1,
  "catalog_id": "polyglot_engineering_standards_catalog",
  "last_verified_on": "2026-03-05",
  "intent": "Define enforceable, cross-language engineering standards for naming, file structure, architecture blueprints, and CI pipeline quality gates.",
  "objectives": [
    "minimize duplicated logic across language implementations",
    "keep function behavior 1:1 via shared contracts and generated wrappers",
    "standardize naming and structure for readability and automation",
    "improve release quality, security posture, and benchmark repeatability"
  ],
  "naming_policy": {
    "cross_language_semantics": [
      "name functions by behavior rather than implementation detail",
      "one function equals one logical operation",
      "use stable semantic identifiers in shared catalogs",
      "keep public API names explicit and predictable",
      "keep naming style consistent per module boundary"
    ],
    "language_surface_styles": {
      "javascript": {
        "function_case": "lowerCamelCase",
        "constant_case": "CONSTANT_CASE",
        "filename_case": "snake_case_or_kebab_case_single_policy_per_layer"
      },
      "typescript": {
        "function_case": "lowerCamelCase",
        "constant_case": "CONSTANT_CASE",
        "filename_case": "snake_case_or_kebab_case_single_policy_per_layer"
      },
      "python": {
        "function_case": "lower_snake_case",
        "constant_case": "UPPER_SNAKE_CASE",
        "module_case": "lowercase_or_lower_snake_case"
      },
      "cpp": {
        "function_case": "project_defined_consistent_style",
        "constant_case": "project_defined_consistent_style",
        "file_structure": "self_contained_headers_and_clear_interface_implementation_split"
      },
      "ruby": {
        "function_case": "snake_case",
        "constant_case": "PascalCase_or_UPPER_CASE_for_constants",
        "predicate_suffix": "question_mark_for_boolean_predicates"
      }
    }
  },
  "function_design_rules": [
    "use verb_object naming where possible",
    "limit positional parameters and prefer grouped input objects for higher arity",
    "make return contracts explicit and stable",
    "keep side effects explicit at language boundaries",
    "split large functions into named sub-operations"
  ],
  "file_organization_policy": {
    "recommended_root_layers": [
      "data/input/shared",
      "brain",
      "scripts",
      "data/output"
    ],
    "directory_responsibility_rules": [
      "shared contracts and registries live only in data/input/shared",
      "runtime logic lives in brain without duplicated registry constants",
      "automation and orchestration lives in scripts",
      "generated code and reports live only in data/output"
    ],
    "generated_artifact_rules": [
      "generated files are never manually edited",
      "generated files must be reproducible from source catalogs"
    ]
  },
  "blueprint_policy": {
    "required_artifacts": [
      "architecture_context_view",
      "architecture_container_view",
      "architecture_component_view",
      "arc42_narrative_sections",
      "adr_decision_log"
    ],
    "minimum_architecture_fields": [
      "stakeholders",
      "concerns",
      "viewpoints",
      "rationale",
      "constraints",
      "quality_attributes"
    ]
  },
  "ui_ux_human_factors_policy": {
    "baseline_targets": {
      "accessibility_level": "WCAG_2_2_AA",
      "minimum_target_size_css_px": 24,
      "preferred_target_size_css_px": 32
    },
    "required_semantic_color_roles": [
      "danger",
      "warning",
      "success",
      "info",
      "neutral"
    ],
    "required_preference_features": [
      "prefers-color-scheme",
      "prefers-contrast",
      "prefers-reduced-motion",
      "prefers-reduced-data",
      "forced-colors"
    ],
    "cognitive_design_rules": [
      "apply_fitts_law_to_high_frequency_actions",
      "apply_hick_hyman_law_to_choice_architecture",
      "reduce_extraneous_cognitive_load",
      "prefer_recognition_over_recall"
    ],
    "measurement_requirements": [
      "task_success_rate",
      "time_on_task",
      "error_rate",
      "accessibility_pass_rate",
      "satisfaction_score"
    ],
    "required_catalog": "data/input/shared/main/ui_ux_blueprint_catalog.json"
  },
  "pipeline_policy": {
    "required_ci_stages": [
      "format",
      "lint_and_typecheck",
      "unit_and_integration_tests",
      "contract_drift_validation",
      "iso_standards_compliance_validation",
      "uiux_blueprint_validation",
      "security_validation",
      "runtime_benchmark_validation"
    ],
    "recommended_release_stages": [
      "conventional_commit_validation",
      "semantic_versioning_decision",
      "changelog_generation",
      "artifact_provenance_capture"
    ]
  },
  "security_and_supply_chain_policy": {
    "frameworks": [
      "NIST_SSDF",
      "OWASP_ASVS",
      "SLSA"
    ],
    "adoption_note": "Apply incrementally with measurable gates; start with baseline controls and increase assurance over time."
  },
