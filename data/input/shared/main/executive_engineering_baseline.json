{
  "schema_version": 1,
  "baseline_id": "aio_executive_engineering_baseline_2026q1",
  "effective_date": "2026-03-05",
  "project": {
    "project_id": "aio",
    "project_name": "AIO",
    "timezone": "America/New_York"
  },
  "decision_model": {
    "mode": "contract_first",
    "principles": [
      "single_logical_operation_per_function",
      "data_catalogs_as_source_of_truth",
      "language_wrappers_as_adapters_only",
      "profile_first_optimization",
      "deterministic_generation_and_reports"
    ]
  },
  "naming_policy": {
    "semantic_rules": [
      "names_must_reflect_observable_behavior",
      "shared_function_ids_are_language_neutral",
      "one_function_id_maps_to_one_wrapper_action",
      "constants_use_explicit_taxonomy_prefixes"
    ],
    "identifier_formats": {
      "function_id": "lower.dot.namespace",
      "symbol_name": "lower_snake_case",
      "object_name": "lower_snake_case",
      "const_name": "UPPER_SNAKE_CASE"
    },
    "filename_policy": {
      "runtime_roots": {
        "roots": ["app", "brain", "main", "renderer", "tests"],
        "allowed_cases": ["snake_case"],
        "legacy_allowed_cases": [],
        "legacy_case_level": "error"
      },
      "script_root": {
        "roots": ["scripts"],
        "allowed_cases": ["snake_case", "kebab-case"],
        "legacy_case_level": "pass"
      }
    }
  },
  "data_storage_policy": {
    "tiers": [
      {
        "tier_id": "contracts",
        "root": "data/input/shared",
        "role": "authoritative_specs",
        "mutable": true
      },
      {
        "tier_id": "runtime_state",
        "root": "data/input/databases",
        "role": "mutable_runtime_state",
        "mutable": true
      },
      {
        "tier_id": "generated",
        "root": "data/output/databases/polyglot-default/build/generated",
        "role": "generated_bindings",
        "mutable": false
      },
      {
        "tier_id": "evidence",
        "root": "data/output/databases/polyglot-default",
        "role": "reports_analysis_research",
        "mutable": true
      }
    ],
    "runtime_forbidden_source_prefixes": ["data/output/"],
    "catalog_contract_requirements": {
      "require_schema_version": true,
      "require_catalog_id": false,
      "legacy_missing_schema_level": "error"
    },
    "json_interop": {
      "rfc_8259_required": true,
      "json_pointer_support_recommended": true,
      "json_patch_support_recommended": true,
      "canonicalization_recommended": true
    }
  },
  "optimization_policy": {
    "strategy": "profile_first",
    "required_artifacts": ["runtime_benchmark_report", "efficiency_audit_report", "uiux_blueprint_report"],
    "thresholds": {
      "max_file_tokens": 16000,
      "max_skill_prompt_tokens": 24,
      "max_automation_prompt_tokens": 36,
      "max_total_tokens_estimate": 43000,
      "max_scope_guardrail_duplicate_count": 20,
      "benchmark_min_function_coverage_ratio": 0.8,
      "benchmark_min_case_count": 20
    },
    "required_scripts": [
      "benchmark:runtime",
      "efficiency:gate",
      "docs:freshness:check",
      "standards:baseline:gate",
      "standards:iso:gate",
      "uiux:blueprint:check"
    ]
  },
  "polyglot_runtime_policy": {
    "benchmark_selected_runtime_required": true,
    "required_languages_run": ["javascript", "python", "cpp"],
    "runtime_benchmark_report_file": "data/output/databases/polyglot-default/reports/polyglot_runtime_benchmark_report.json",
    "runtime_winner_map_file": "data/output/databases/polyglot-default/reports/polyglot_runtime_winner_map.json",
    "script_runtime_swap_report_file": "data/output/databases/polyglot-default/analysis/script_runtime_swap_report.json",
    "required_swap_controls": {
      "auto_select_best": true
    }
  },
  "research_governance_policy": {
    "required_catalogs": [
      "data/input/shared/main/ui_component_blueprint_catalog.json",
      "data/input/shared/main/rendering_runtime_policy_catalog.json",
      "data/input/shared/main/search_strategy_routing_catalog.json",
      "data/input/shared/main/memory_data_lifecycle_policy_catalog.json",
      "data/input/shared/main/ai_automation_safety_speech_catalog.json",
      "data/input/shared/main/token_usage_optimization_policy_catalog.json"
    ]
  },
  "ui_ux_policy": {
    "required_catalog": "data/input/shared/main/ui_ux_blueprint_catalog.json",
    "required_component_catalog": "data/input/shared/main/ui_component_blueprint_catalog.json",
    "required_scripts": ["uiux:blueprint", "uiux:blueprint:check"],
    "minimum_controls": [
      "semantic_color_roles_with_psychology_rationale",
      "minimum_target_size_24_css_px",
      "preference_media_features_support",
      "accessibility_contrast_and_non_color_redundancy",
      "task_level_ux_measurement_plan"
    ],
    "required_media_features": [
      "prefers-color-scheme",
      "prefers-contrast",
      "prefers-reduced-motion",
      "prefers-reduced-data",
      "forced-colors"
    ],
    "minimum_target_size_css_px": 24
  },
  "workflow_policy": {
    "required_gate_order": [
      "workflow:preflight",
      "workflow:order:gate",
      "contracts:validate",
      "standards:baseline:gate",
      "standards:iso:gate",
      "uiux:blueprint:check",
      "governance:hard:gate",
      "efficiency:gate",
      "refactor:gate"
    ],
    "agent_scope_contract": {
      "project_scope_ref": "source://project_scope",
      "required_scope_guardrail_tokens": [
        "two-pass wrapper order",
        "governance:hard:gate",
        "agents:validate",
        "standards:baseline:gate",
        "standards:iso:gate",
        "uiux:blueprint:check"
      ]
    }
  },
