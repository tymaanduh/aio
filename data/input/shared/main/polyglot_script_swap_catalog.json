{
  "schema_version": 1,
  "catalog_id": "aio_polyglot_script_swap_catalog",
  "runtime_contract": {
    "baseline_language": "javascript",
    "default_language_order": [
      "javascript",
      "python",
      "cpp"
    ],
    "fallback_language": "javascript",
    "env_overrides": {
      "preferred_language": "AIO_SCRIPT_RUNTIME_LANGUAGE",
      "ordered_languages": "AIO_SCRIPT_RUNTIME_ORDER",
      "disable_swaps": "AIO_SCRIPT_RUNTIME_DISABLE"
    }
  },
  "adapters": {
    "javascript": {
      "kind": "native_node"
    },
    "python": {
      "kind": "python_node_bridge",
      "bridge_script": "scripts/polyglot/swaps/python/node_script_bridge.py"
    },
    "cpp": {
      "kind": "cpp_node_bridge",
      "bridge_script": "scripts/polyglot/swaps/cpp/cpp_node_bridge.js"
    }
  },
  "stage_script_map": {
    "workflow_preflight": {
      "script_file": "scripts/workflow-preflight.js"
    },
    "prune_workflow_artifacts": {
      "script_file": "scripts/prune-workflow-artifacts.js"
    },
    "generate_uiux_blueprint": {
      "script_file": "scripts/generate-uiux-blueprint.js"
    },
    "hard_governance_gate": {
      "script_file": "scripts/hard-governance-gate.js"
    },
    "validate_agent_registry": {
      "script_file": "scripts/validate-agent-registry.js"
    },
    "validate_wrapper_contracts": {
      "script_file": "scripts/validate-wrapper-contracts.js"
    },
    "codex_efficiency_audit": {
      "script_file": "scripts/codex-efficiency-audit.js"
    },
    "polyglot_default_pipeline": {
      "script_file": "scripts/polyglot-default-pipeline.js"
    },
    "data_separation_audit": {
      "script_file": "scripts/data-separation-audit.js"
    },
    "build_agent_workflow_shards": {
      "script_file": "scripts/build-agent-workflow-shards.js"
    },
    "validate_workflow_pipeline_order": {
      "script_file": "scripts/validate-workflow-pipeline-order.js"
    },
    "validate_script_swap_catalog": {
      "script_file": "scripts/validate-script-swap-catalog.js"
    }
  }
}
