{
  "name": "aio",
  "version": "1.0.0",
  "description": "Desktop dictionary builder with local autosave and labels",
  "main": "main.js",
  "scripts": {
    "start": "node scripts/run-electron.js",
    "dev": "node scripts/run-electron.js",
    "test": "node --test tests/*.test.js",
    "dx12:doctor": "node scripts/dx12-doctor.js",
    "dx12:install:wsl-prereqs": "node scripts/dx12-install-wsl-prereqs.js",
    "dx12:configure": "cmake -S native/dx12 -B native/dx12/build -G \"Visual Studio 17 2022\" -A x64",
    "dx12:build": "cmake --build native/dx12/build --config Release",
    "dx12:configure:mingw": "node scripts/dx12-configure-mingw.js",
    "dx12:build:mingw": "node scripts/dx12-build-mingw.js",
    "polyglot:default": "node scripts/polyglot-default-pipeline.js",
    "polyglot:create": "node scripts/polyglot-default-pipeline.js --mode create",
    "polyglot:maintain": "node scripts/polyglot-default-pipeline.js --mode maintain",
    "workflow:general": "node scripts/general-workflow.js --mode auto",
    "workflow:continue": "node scripts/general-workflow.js --mode maintain",
    "workflow:cpp": "node scripts/general-workflow.js --mode maintain --script-runtime cpp --script-runtime-order cpp,python,javascript",
    "workflow:python": "node scripts/general-workflow.js --mode maintain --script-runtime python --script-runtime-order python,cpp,javascript",
    "workflow:fast": "node scripts/general-workflow.js --mode maintain --fast --skip-preflight --skip-output-format",
    "governance:hard": "node scripts/hard-governance-gate.js",
    "governance:hard:gate": "node scripts/hard-governance-gate.js --enforce",
    "standards:baseline": "node scripts/standards-baseline-gate.js",
    "standards:baseline:gate": "node scripts/standards-baseline-gate.js --enforce",
    "standards:iso": "node scripts/iso-standards-compliance-gate.js",
    "standards:iso:gate": "node scripts/iso-standards-compliance-gate.js --enforce",
    "uiux:blueprint": "node scripts/generate-uiux-blueprint.js",
    "uiux:blueprint:check": "node scripts/generate-uiux-blueprint.js --check --enforce",
    "workflow:shards": "node scripts/build-agent-workflow-shards.js",
    "workflow:prune": "node scripts/prune-workflow-artifacts.js",
    "workflow:order": "node scripts/validate-workflow-pipeline-order.js",
    "workflow:order:gate": "node scripts/validate-workflow-pipeline-order.js --enforce",
    "workflow:preflight": "node scripts/workflow-preflight.js",
    "wrapper:run": "node scripts/run-unified-wrapper.js",
    "agent:request-access": "node scripts/agent-access-request.js",
    "updates:scan": "node scripts/repo-update-log.js scan",
    "updates:watch": "node scripts/repo-update-log.js watch",
    "agents:validate": "node scripts/validate-agent-registry.js",
    "agents:scope-sync": "node scripts/sync-agent-skill-scope.js",
    "efficiency:audit": "node scripts/codex-efficiency-audit.js",
    "efficiency:gate": "node scripts/codex-efficiency-audit.js --enforce",
    "token:maintain": "npm run agents:scope-sync && npm run automations:optimize -- --apply && npm run efficiency:gate",
    "optimization:backlog": "node scripts/generate-runtime-optimization-backlog.js",
    "docs:catalog": "node scripts/generate-file-catalog-docs.js",
    "visuals:runtime": "node scripts/generate-runtime-visuals.js",
    "docs:generate": "node scripts/generate-documentation-suite.js",
    "docs:freshness:check": "node scripts/docs-freshness-check.js --enforce",
    "local:governance": "node scripts/run-local-governance.js --strict",
    "local:governance:soft": "node scripts/run-local-governance.js",
    "automations:audit": "node scripts/optimize-codex-automations.js",
    "automations:optimize": "node scripts/optimize-codex-automations.js --apply",
    "wrappers:generate": "node scripts/generate-wrapper-polyglot-bindings.js",
    "wrappers:check": "node scripts/generate-wrapper-polyglot-bindings.js --check",
    "scripts:polyglot:generate": "node scripts/generate-script-polyglot-equivalents.js",
    "scripts:polyglot:check": "node scripts/generate-script-polyglot-equivalents.js --check",
    "benchmark:runtime": "node scripts/polyglot-runtime-benchmark.js",
    "contracts:validate": "node scripts/validate-wrapper-contracts.js",
    "script-swaps:validate": "node scripts/validate-script-swap-catalog.js",
    "codex:desktop:validate": "node scripts/validate-codex-desktop-compat.js && node scripts/validate-agent-registry.js",
    "codex:desktop:sync:dry-run": "node scripts/sync-agent-skill-scope.js && node scripts/validate-codex-desktop-compat.js && node scripts/validate-agent-registry.js && node scripts/codex-desktop-sync.js --dry-run",
    "codex:desktop:sync": "node scripts/sync-agent-skill-scope.js && node scripts/validate-codex-desktop-compat.js && node scripts/validate-agent-registry.js && node scripts/codex-desktop-sync.js",
    "audit:data-separation": "node scripts/data-separation-audit.js",
    "dictionary:compile:descriptors": "node scripts/word-machine-descriptor-compile.js",
    "dist:win": "electron-builder --win nsis --x64",
    "dist:win-portable": "electron-builder --win portable --x64",
    "lint": "eslint . --ext .js --ignore-pattern dist --ignore-pattern native",
    "lint:fix": "eslint . --ext .js --ignore-pattern dist --ignore-pattern native --fix",
    "refactor:gate": "node scripts/refactor-blocking-gate.js",
    "format": "prettier --write \"**/*.{js,json,css,html,md}\" --ignore-path .prettierignore",
    "format:check": "prettier --check \"**/*.{js,json,css,html,md}\" --ignore-path .prettierignore"
  },
  "keywords": [
    "dictionary",
    "desktop",
    "electron"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "electron": "^35.7.5",
    "electron-builder": "^26.8.1",
    "eslint": "^8.57.1",
    "prettier": "^3.8.1",
    "ws": "^8.19.0"
  },
  "build": {
    "appId": "com.tymoj.aio",
    "productName": "AIO",
    "directories": {
      "output": "dist"
    },
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "shortcutName": "AIO"
    }
  }
}
