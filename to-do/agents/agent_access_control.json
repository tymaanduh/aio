{
  "version": "1.5.0",
  "system": {
    "name": "agent-access-control-system",
    "policy_mode": "deny_by_default_for_non_startup_tools",
    "request_required_for_non_startup_tools": true,
    "request_log_file": "data/input/databases/agent_access_requests.ndjson",
    "request_command": "npm run agent:request-access -- --agent-id <agent-id> --requested-tool <tool-id> --privilege-flag <flag-id> --reason \"<why-needed>\"",
    "request_contract": {
      "required_fields": [
        "agent_id",
        "requested_tool",
        "privilege_flag",
        "reason"
      ],
      "reason_min_chars": 10,
      "default_status": "pending"
    },
    "update_log": {
      "events_file": "data/output/logs/change-log/update_events.ndjson",
      "sessions_file": "data/output/logs/change-log/sessions.ndjson",
      "state_file": "data/output/logs/change-log/state_snapshot.json",
      "scan_command": "npm run updates:scan -- --actor <agent-id> --scope \"<scope>\"",
      "watch_command": "npm run updates:watch -- --actor <agent-id> --session-id <session-id>"
    },
    "preflight": {
      "required": true,
      "command": "npm run workflow:preflight -- --scope \"<scope>\"",
      "default_report_file": "data/output/databases/polyglot-default/analysis/workflow_preflight_report.json",
      "skip_flag": "--skip-preflight"
    },
    "project_scope": {
      "project_id": "aio",
      "policy_version": "2026-03-05",
      "allowed_roots": [
        "app/",
        "brain/",
        "data/input/",
        "data/output/",
        "main/",
        "renderer/",
        "scripts/",
        "tests/",
        "to-do/"
      ],
      "runtime_roots": [
        "brain/",
        "data/input/",
        "data/output/",
        "to-do/"
      ],
      "output_only_root": "data/output/"
    }
  },
  "privilege_flags": [
    "TOOL_ALIAS_SYNC",
    "TOOL_ARGUMENT_DISCOVERY",
    "TOOL_EDIT_AGENTS",
    "TOOL_EDIT_CODE",
    "TOOL_EDIT_DATA_CATALOGS",
