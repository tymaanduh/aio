{
  "id": "language-bridge-agent",
  "display_name": "Language Bridge Agent",
  "purpose": "Bridge code, pseudocode, and plain-English language artifacts into searchable dictionary-linked state.",
  "skill_stack": [
    "code-pseudocode-english-bridge",
    "linked-naming-governor",
    "pre-assign-naming-gate",
    "dictionary-alias-sync",
    "refactor-blocking-gate"
  ],
  "workflow": [
    "Capture user/assistant and dictionary source text.",
    "Extract code tokens, pseudocode phrases, and english terms.",
    "Build keyword index, triad map, and glossary artifacts.",
    "Link artifacts to entry/document IDs in bridge state.",
    "Run lint/test/refactor gate.",
    "Run npm run governance:hard:gate and stop on failures before completion."
  ],
  "blocking_checks": [
    "Bridge state schema remains valid",
    "Entry linkage refs are consistent",
    "All blocking validation checks pass",
    "Hard governance gate passes (npm run governance:hard:gate)."
  ],
  "role": "bridge_indexer",
  "controls_cap": 4,
  "allowed_controls": [
    "data.edit.language_bridge",
    "workflow.capture.sources",
    "analysis.triad_map",
    "governance.alias_sync"
  ],
  "startup_tools": [
    "context_reader",
    "code_search",
    "bridge_indexer",
    "validator"
  ],
  "startup_tool_cap": 4,
  "access_policy_ref": "source://agent_access_control#agents/language-bridge-agent",
  "tool_access_request": {
    "required_for_non_startup_tools": true,
    "request_command": "npm run agent:request-access -- --agent-id <agent-id> --requested-tool <tool-id> --privilege-flag <flag-id> --reason \"<why-needed>\"",
    "request_log_file": "source://request_log_file",
    "required_fields": [
      "agent_id",
      "requested_tool",
      "privilege_flag",
      "reason"
    ]
  },
  "file_update_logging": {
    "required": true,
    "scan_on_start": true,
    "scan_on_finish": true,
    "watch_for_long_edit_passes": true,
    "events_file": "source://update_events_file",
    "sessions_file": "source://update_sessions_file",
    "scan_command": "npm run updates:scan -- --actor language-bridge-agent --scope \"<scope>\"",
    "watch_command": "npm run updates:watch -- --actor language-bridge-agent --session-id <session-id>"
  },
  "project_scope_ref": "source://project_scope",
  "scope_guardrails_ref": "source://scope_guardrails#default"
}
