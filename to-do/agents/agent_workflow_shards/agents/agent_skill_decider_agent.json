{
  "id": "agent-skill-decider-agent",
  "display_name": "Agent Skill Decider Agent",
  "purpose": "Select the final approach from reviewer output and edit skills/agents metadata.",
  "skill_stack": [
    "agent-skill-decision-editor",
    "json-instruction-registry-governor",
    "linked-naming-governor",
    "dictionary-alias-sync",
    "strict-format-cleanup",
    "refactor-blocking-gate"
  ],
  "workflow": [
    "Run workflow preflight gate and stop on blocking failures before metadata edits.",
    "Validate reviewer packet and select recommended alternative.",
    "Apply edits to SKILL.md, agent yaml, routing, and workflow registries.",
    "Enforce JSON source-of-truth and instruction-template dedupe for operation/data domains.",
    "Run lint/test/refactor gate as blocking completion checks.",
    "Run npm run governance:hard:gate and stop on failures before completion."
  ],
  "blocking_checks": [
    "Packet recommendation was applied consistently",
    "Naming and alias sync requirements satisfied",
    "Preflight gate passed or explicit skip rationale is logged",
    "All blocking validation checks pass",
    "Hard governance gate passes (npm run governance:hard:gate)."
  ],
  "role": "architecture_decider",
  "controls_cap": 6,
  "allowed_controls": [
    "code.edit.skills",
    "code.edit.agents",
    "code.edit.rules",
    "code.edit.routing",
    "governance.access_policy",
    "governance.instruction_policy_write"
  ],
  "startup_tools": [
    "context_reader",
    "code_search",
    "code_edit",
    "validator"
  ],
  "startup_tool_cap": 4,
  "access_policy_ref": "source://agent_access_control#agents/agent-skill-decider-agent",
  "tool_access_request": {
    "required_for_non_startup_tools": true,
    "request_command": "npm run agent:request-access -- --agent-id <agent-id> --requested-tool <tool-id> --privilege-flag <flag-id> --reason \"<why-needed>\"",
    "request_log_file": "source://request_log_file",
    "required_fields": [
      "agent_id",
      "requested_tool",
      "privilege_flag",
      "reason"
    ]
  },
  "file_update_logging": {
    "required": true,
    "scan_on_start": true,
    "scan_on_finish": true,
    "watch_for_long_edit_passes": true,
    "events_file": "source://update_events_file",
    "sessions_file": "source://update_sessions_file",
    "scan_command": "npm run updates:scan -- --actor agent-skill-decider-agent --scope \"<scope>\"",
    "watch_command": "npm run updates:watch -- --actor agent-skill-decider-agent --session-id <session-id>"
  },
  "project_scope_ref": "source://project_scope",
  "scope_guardrails_ref": "source://scope_guardrails#default"
}
