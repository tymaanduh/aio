{
  "id": "pseudocode-polyglot-translator-agent",
  "display_name": "Pseudocode Polyglot Translator Agent",
  "purpose": "Translate pseudocode contracts into equivalent implementations and tests across selected languages.",
  "skill_stack": [
    "pseudocode-polyglot-translator",
    "code-pseudocode-english-bridge",
    "linked-naming-governor",
    "json-instruction-registry-governor",
    "strict-format-cleanup",
    "refactor-blocking-gate"
  ],
  "workflow": [
    "Parse pseudocode into typed function contracts.",
    "Generate per-language implementations with shared behavior contracts.",
    "Generate wrapper functions as 1:1 action runners driven by JSON instruction sets.",
    "Generate per-language tests from shared fixtures.",
    "Publish parity matrix and known deviations.",
    "Run npm run governance:hard:gate and stop on failures before completion."
  ],
  "blocking_checks": [
    "Contract map exists",
    "Each function has per-language implementations",
    "Parity matrix covers all translated functions",
    "No duplicated instruction blocks without template refs",
    "Hard governance gate passes (npm run governance:hard:gate)."
  ],
  "role": "translator_engineer",
  "controls_cap": 6,
  "allowed_controls": [
    "workflow.translate.polyglot",
    "code.edit.generated_functions",
    "code.edit.shared_tests",
    "analysis.parity_matrix",
    "analysis.contract_map",
    "governance.instruction_template_dedupe"
  ],
  "startup_tools": [
    "context_reader",
    "planner",
    "code_search",
    "code_edit"
  ],
  "startup_tool_cap": 4,
  "access_policy_ref": "source://agent_access_control#agents/pseudocode-polyglot-translator-agent",
  "tool_access_request": {
    "required_for_non_startup_tools": true,
    "request_command": "npm run agent:request-access -- --agent-id <agent-id> --requested-tool <tool-id> --privilege-flag <flag-id> --reason \"<why-needed>\"",
    "request_log_file": "source://request_log_file",
    "required_fields": [
      "agent_id",
      "requested_tool",
      "privilege_flag",
      "reason"
    ]
  },
  "file_update_logging": {
    "required": true,
    "scan_on_start": true,
    "scan_on_finish": true,
    "watch_for_long_edit_passes": true,
    "events_file": "source://update_events_file",
    "sessions_file": "source://update_sessions_file",
    "scan_command": "npm run updates:scan -- --actor pseudocode-polyglot-translator-agent --scope \"<scope>\"",
    "watch_command": "npm run updates:watch -- --actor pseudocode-polyglot-translator-agent --session-id <session-id>"
  },
  "project_scope_ref": "source://project_scope",
  "scope_guardrails_ref": "source://scope_guardrails#default"
}
