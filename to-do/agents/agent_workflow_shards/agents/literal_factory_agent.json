{
  "id": "literal-factory-agent",
  "display_name": "Literal Factory Agent",
  "purpose": "Remove hardcoded text and action duplication using shared factories and pattern maps.",
  "skill_stack": [
    "linked-naming-governor",
    "literal-factory-dehardcode",
    "strict-format-cleanup",
    "refactor-blocking-gate"
  ],
  "workflow": [
    "Identify repeated literals/actions.",
    "Move shared strings/maps to PATTERN_* constants.",
    "Use factory helpers for label/action generation.",
    "Retain existing UI behavior and text output.",
    "Run lint/test/refactor gate.",
    "Run npm run governance:hard:gate and stop on failures before completion."
  ],
  "blocking_checks": [
    "No repeated hardcoded labels in targeted blocks",
    "Factory + pattern extraction applied",
    "Behavior parity preserved",
    "Hard governance gate passes (npm run governance:hard:gate)."
  ],
  "role": "literal_refactor",
  "controls_cap": 3,
  "allowed_controls": [
    "code.edit.literals",
    "governance.pattern_registry",
    "governance.refactor_gate"
  ],
  "startup_tools": [
    "context_reader",
    "code_search",
    "code_edit"
  ],
  "startup_tool_cap": 3,
  "access_policy_ref": "source://agent_access_control#agents/literal-factory-agent",
  "tool_access_request": {
    "required_for_non_startup_tools": true,
    "request_command": "npm run agent:request-access -- --agent-id <agent-id> --requested-tool <tool-id> --privilege-flag <flag-id> --reason \"<why-needed>\"",
    "request_log_file": "source://request_log_file",
    "required_fields": [
      "agent_id",
      "requested_tool",
      "privilege_flag",
      "reason"
    ]
  },
  "file_update_logging": {
    "required": true,
    "scan_on_start": true,
    "scan_on_finish": true,
    "watch_for_long_edit_passes": true,
    "events_file": "source://update_events_file",
    "sessions_file": "source://update_sessions_file",
    "scan_command": "npm run updates:scan -- --actor literal-factory-agent --scope \"<scope>\"",
    "watch_command": "npm run updates:watch -- --actor literal-factory-agent --session-id <session-id>"
  },
  "project_scope_ref": "source://project_scope",
  "scope_guardrails_ref": "source://scope_guardrails#default"
}
