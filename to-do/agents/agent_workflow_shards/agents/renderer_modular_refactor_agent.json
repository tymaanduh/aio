{
  "id": "renderer-modular-refactor-agent",
  "display_name": "Renderer Modular Refactor Agent",
  "purpose": "Keep renderer wrapper-focused and dispatch-first while extracting domain logic.",
  "skill_stack": [
    "linked-naming-governor",
    "renderer-wrapper-modularizer",
    "renderer-dispatch-cutover",
    "strict-format-cleanup",
    "refactor-blocking-gate"
  ],
  "workflow": [
    "Select extraction slice by domain ownership.",
    "Move logic to module with linked naming chain.",
    "Replace wrappers with dispatch-object calls.",
    "Align extracted keys with group_sets and dispatch specs.",
    "Run lint/test/refactor gate.",
    "Run npm run governance:hard:gate and stop on failures before completion."
  ],
  "blocking_checks": [
    "No wrapper-wall regressions",
    "Dispatch/group alignment is exact",
    "Renderer size gate remains green",
    "Hard governance gate passes (npm run governance:hard:gate)."
  ],
  "role": "renderer_refactor",
  "controls_cap": 4,
  "allowed_controls": [
    "code.edit.renderer",
    "governance.dispatch",
    "governance.naming",
    "governance.refactor_gate"
  ],
  "startup_tools": [
    "context_reader",
    "code_search",
    "code_edit",
    "validator"
  ],
  "startup_tool_cap": 4,
  "access_policy_ref": "source://agent_access_control#agents/renderer-modular-refactor-agent",
  "tool_access_request": {
    "required_for_non_startup_tools": true,
    "request_command": "npm run agent:request-access -- --agent-id <agent-id> --requested-tool <tool-id> --privilege-flag <flag-id> --reason \"<why-needed>\"",
    "request_log_file": "source://request_log_file",
    "required_fields": [
      "agent_id",
      "requested_tool",
      "privilege_flag",
      "reason"
    ]
  },
  "file_update_logging": {
    "required": true,
    "scan_on_start": true,
    "scan_on_finish": true,
    "watch_for_long_edit_passes": true,
    "events_file": "source://update_events_file",
    "sessions_file": "source://update_sessions_file",
    "scan_command": "npm run updates:scan -- --actor renderer-modular-refactor-agent --scope \"<scope>\"",
    "watch_command": "npm run updates:watch -- --actor renderer-modular-refactor-agent --session-id <session-id>"
  },
  "project_scope_ref": "source://project_scope",
  "scope_guardrails_ref": "source://scope_guardrails#default"
}
