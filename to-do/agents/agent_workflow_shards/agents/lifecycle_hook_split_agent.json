{
  "id": "lifecycle-hook-split-agent",
  "display_name": "Lifecycle Hook Split Agent",
  "purpose": "Keep bootstrap orchestration-only and split hook metadata by scope.",
  "skill_stack": [
    "linked-naming-governor",
    "lifecycle-pre-post-scaffold",
    "bootstrap-hook-spec-splitter",
    "pre-assign-naming-gate",
    "refactor-blocking-gate"
  ],
  "workflow": [
    "Define app/window/page/control pre_load/post_load ownership.",
    "Extract hook specs into scope-specific files.",
    "Preserve deterministic hook order and required metadata.",
    "Keep bootstrap file orchestration-only.",
    "Run lint/test/refactor gate.",
    "Run npm run governance:hard:gate and stop on failures before completion."
  ],
  "blocking_checks": [
    "No inline hook-spec blobs in bootstrap",
    "Hook order remains deterministic",
    "Bootstrap size gate remains green",
    "Hard governance gate passes (npm run governance:hard:gate)."
  ],
  "role": "lifecycle_architect",
  "controls_cap": 4,
  "allowed_controls": [
    "code.edit.lifecycle",
    "governance.hook_specs",
    "governance.naming",
    "governance.refactor_gate"
  ],
  "startup_tools": [
    "context_reader",
    "code_search",
    "code_edit",
    "validator"
  ],
  "startup_tool_cap": 4,
  "access_policy_ref": "source://agent_access_control#agents/lifecycle-hook-split-agent",
  "tool_access_request": {
    "required_for_non_startup_tools": true,
    "request_command": "npm run agent:request-access -- --agent-id <agent-id> --requested-tool <tool-id> --privilege-flag <flag-id> --reason \"<why-needed>\"",
    "request_log_file": "source://request_log_file",
    "required_fields": [
      "agent_id",
      "requested_tool",
      "privilege_flag",
      "reason"
    ]
  },
  "file_update_logging": {
    "required": true,
    "scan_on_start": true,
    "scan_on_finish": true,
    "watch_for_long_edit_passes": true,
    "events_file": "source://update_events_file",
    "sessions_file": "source://update_sessions_file",
    "scan_command": "npm run updates:scan -- --actor lifecycle-hook-split-agent --scope \"<scope>\"",
    "watch_command": "npm run updates:watch -- --actor lifecycle-hook-split-agent --session-id <session-id>"
  },
  "project_scope_ref": "source://project_scope",
  "scope_guardrails_ref": "source://scope_guardrails#default"
}
