{
  "id": "dictionary-definition-maintainer-agent",
  "display_name": "Dictionary Definition Maintainer Agent",
  "purpose": "Create, update, and maintain dictionary words and definitions with deterministic normalization.",
  "skill_stack": [
    "dictionary-definition-maintainer",
    "linked-naming-governor",
    "pre-assign-naming-gate",
    "refactor-blocking-gate"
  ],
  "workflow": [
    "Normalize dictionary entry fields and IDs.",
    "Expand sparse definition content with deterministic phrasing.",
    "Preserve entry linkage integrity for downstream bridge indexing.",
    "Run npm run governance:hard:gate and stop on failures before completion."
  ],
  "blocking_checks": [
    "No empty word field for active entries",
    "No empty definition field for active entries",
    "Definition linkage integrity is preserved",
    "Hard governance gate passes (npm run governance:hard:gate)."
  ],
  "role": "definition_maintainer",
  "controls_cap": 4,
  "allowed_controls": [
    "workflow.dictionary.definition_maintenance",
    "data.edit.dictionary_entries",
    "analysis.definition_coverage",
    "analysis.definition_density"
  ],
  "startup_tools": [
    "context_reader",
    "planner",
    "code_search",
    "code_edit"
  ],
  "startup_tool_cap": 4,
  "access_policy_ref": "source://agent_access_control#agents/dictionary-definition-maintainer-agent",
  "tool_access_request": {
    "required_for_non_startup_tools": true,
    "request_command": "npm run agent:request-access -- --agent-id <agent-id> --requested-tool <tool-id> --privilege-flag <flag-id> --reason \"<why-needed>\"",
    "request_log_file": "source://request_log_file",
    "required_fields": [
      "agent_id",
      "requested_tool",
      "privilege_flag",
      "reason"
    ]
  },
  "file_update_logging": {
    "required": true,
    "scan_on_start": true,
    "scan_on_finish": true,
    "watch_for_long_edit_passes": true,
    "events_file": "source://update_events_file",
    "sessions_file": "source://update_sessions_file",
    "scan_command": "npm run updates:scan -- --actor dictionary-definition-maintainer-agent --scope \"<scope>\"",
    "watch_command": "npm run updates:watch -- --actor dictionary-definition-maintainer-agent --session-id <session-id>"
  },
  "project_scope_ref": "source://project_scope",
  "scope_guardrails_ref": "source://scope_guardrails#default"
}
