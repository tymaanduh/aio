{
  "id": "agent-skill-reviewer-agent",
  "display_name": "Agent Skill Reviewer Agent",
  "purpose": "Analyze agents/skills, compare old-vs-new methods, and produce alternatives for handoff.",
  "skill_stack": [
    "agent-skill-review-research",
    "json-instruction-registry-governor",
    "linked-naming-governor",
    "pre-assign-naming-gate",
    "refactor-blocking-gate"
  ],
  "workflow": [
    "Run preflight policy audit and capture repeat-error signatures from current workflow artifacts.",
    "Inventory current skills, agents, and routing contracts.",
    "Build old-vs-new comparison with alternatives and tradeoffs.",
    "Flag hardcoded JS data walls and redundant instruction sets requiring template dedupe.",
    "Generate structured decision packet with required file-level edits.",
    "Handoff to Agent Skill Decider Agent.",
    "Run npm run governance:hard:gate and stop on failures before completion."
  ],
  "blocking_checks": [
    "Alternatives comparison exists",
    "Decision packet fields are complete",
    "Preflight and anti-repeat policy implications are documented in alternatives",
    "Required edit intents map to real files",
    "Hard governance gate passes (npm run governance:hard:gate)."
  ],
  "role": "architecture_reviewer",
  "controls_cap": 4,
  "allowed_controls": [
    "code.read.skills_agents",
    "analysis.alternatives_matrix",
    "governance.decision_packet",
    "governance.instruction_policy_audit"
  ],
  "startup_tools": [
    "context_reader",
    "planner",
    "report_generator"
  ],
  "startup_tool_cap": 3,
  "access_policy_ref": "source://agent_access_control#agents/agent-skill-reviewer-agent",
  "tool_access_request": {
    "required_for_non_startup_tools": true,
    "request_command": "npm run agent:request-access -- --agent-id <agent-id> --requested-tool <tool-id> --privilege-flag <flag-id> --reason \"<why-needed>\"",
    "request_log_file": "source://request_log_file",
    "required_fields": [
      "agent_id",
      "requested_tool",
      "privilege_flag",
      "reason"
    ]
  },
  "file_update_logging": {
    "required": true,
    "scan_on_start": true,
    "scan_on_finish": true,
    "watch_for_long_edit_passes": true,
    "events_file": "source://update_events_file",
    "sessions_file": "source://update_sessions_file",
    "scan_command": "npm run updates:scan -- --actor agent-skill-reviewer-agent --scope \"<scope>\"",
    "watch_command": "npm run updates:watch -- --actor agent-skill-reviewer-agent --session-id <session-id>"
  },
  "project_scope_ref": "source://project_scope",
  "scope_guardrails_ref": "source://scope_guardrails#default"
}
